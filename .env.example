# ET AI Concierge - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
DEPLOYMENT_PHASE=phase_1
DEBUG_MODE=false
USE_MOCK_DATA=true

# =============================================================================
# CORE LLM APIS (Phase 1)
# =============================================================================
# Groq API (Recommended for fast inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI API (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# LLM Settings
MAX_TOKENS=1000
TEMPERATURE=0.7

# =============================================================================
# PHASE 2: CLOUDFLARE AI & MARKET INTELLIGENCE
# =============================================================================
# Cloudflare AI Agent API
CLOUDFLARE_AI_API_KEY=your_cloudflare_ai_key_here

# ET Content API
ET_API_KEY=your_et_api_key_here

# Market Data APIs
NSE_API_KEY=your_nse_api_key_here
BSE_API_KEY=your_bse_api_key_here

# Regulatory Monitoring
REGULATORY_WEBHOOK_URL=https://your-domain.com/webhooks/regulatory

# =============================================================================
# PHASE 3: VOICE & WHATSAPP INTEGRATION
# =============================================================================
# Azure Speech Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=centralindia

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
WHATSAPP_BUSINESS_NUMBER=whatsapp:+14155238886

# =============================================================================
# PHASE 4: ENTERPRISE & COMPLIANCE
# =============================================================================
# Regulatory APIs
SEBI_API_KEY=your_sebi_api_key_here
RBI_API_KEY=your_rbi_api_key_here

# Enterprise Integrations
SALESFORCE_API_KEY=your_salesforce_key_here
HUBSPOT_API_KEY=your_hubspot_key_here
ZENDESK_API_KEY=your_zendesk_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# PostgreSQL (for user data and analytics)
DATABASE_URL=postgresql://username:password@localhost:5432/et_concierge

# MongoDB (for document storage)
MONGODB_URL=mongodb://localhost:27017/et_concierge

# Cache and Session Settings
CACHE_TTL=3600
SESSION_TIMEOUT=1800

# =============================================================================
# UI/UX CONFIGURATION
# =============================================================================
UI_THEME=light
ENABLE_ANIMATIONS=true
AUTO_REFRESH_INTERVAL=30
MAX_CHAT_HISTORY=50

# =============================================================================
# BUSINESS RULES & COMPLIANCE
# =============================================================================
# Investment Limits
MAX_INVESTMENT_AMOUNT=1000000
MIN_USER_AGE=18
MAX_USER_AGE=80

# Compliance Settings
REQUIRE_RISK_ASSESSMENT=true
REQUIRE_KYC=false
DATA_RETENTION_DAYS=365

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
GA_TRACKING_ID=your_ga_tracking_id_here

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# CLOUD DEPLOYMENT
# =============================================================================
# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=et-concierge-assets

# Google Cloud
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Azure
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_RESOURCE_GROUP=et-concierge-rg

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Settings
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption
ENCRYPTION_KEY=your_encryption_key_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Flask/FastAPI Settings (for webhooks)
FLASK_ENV=development
FLASK_DEBUG=true
API_PORT=5000

# Streamlit Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Testing
PYTEST_TIMEOUT=30
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/et_concierge_test

# =============================================================================
# FEATURE FLAGS (Override config.py defaults)
# =============================================================================
# Core Features
ENABLE_AGENT_PIPELINE=true
ENABLE_LLM_ENHANCEMENT=true
ENABLE_ANALYTICS=true

# Phase 2 Features
ENABLE_CLOUDFLARE_AI=false
ENABLE_MARKET_DATA=false
ENABLE_PERSONALIZATION=false

# Phase 3 Features
ENABLE_VOICE_INTERFACE=false
ENABLE_WHATSAPP=false
ENABLE_MULTILINGUAL=false

# Phase 4 Features
ENABLE_AUTONOMOUS_ADVISORY=false
ENABLE_PORTFOLIO_MGMT=false
ENABLE_SEBI_COMPLIANCE=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/et-concierge.log
MAX_LOG_SIZE=100MB
LOG_BACKUP_COUNT=5

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Worker Configuration
WORKER_PROCESSES=4
WORKER_THREADS=2
WORKER_TIMEOUT=30

# Connection Pools
DB_POOL_SIZE=20
REDIS_POOL_SIZE=10
HTTP_POOL_SIZE=100

# Caching
ENABLE_RESPONSE_CACHE=true
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=1000

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================
# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=noreply@et-concierge.com

# Slack Notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SLACK_CHANNEL=#et-concierge-alerts

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
# Database Backup
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=et-concierge-backups

# Health Check URLs
HEALTH_CHECK_URL=https://your-domain.com/health
UPTIME_MONITOR_URL=https://uptimerobot.com/api/v2/

# =============================================================================
# CUSTOM BUSINESS LOGIC
# =============================================================================
# ET Specific Settings
ET_BRAND_PRIMARY_COLOR=#1B365D
ET_BRAND_SECONDARY_COLOR=#FF6B35
ET_SUPPORT_EMAIL=support@economictimes.com
ET_SUPPORT_PHONE=+91-22-6635-3535

# Regional Settings
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
SUPPORTED_REGIONS=IN,US,UK

# Content Settings
DEFAULT_LANGUAGE=english
CONTENT_REFRESH_INTERVAL=3600
MAX_CONTENT_AGE_DAYS=30